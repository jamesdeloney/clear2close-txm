DATABASE_URL=
PORT=4000
NODE_ENV=development

# Gmail API — OAuth2 credentials for sending emails
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# 2. Set app type to "Web application"
# 3. Add http://localhost:3333/callback as an Authorized redirect URI
# 4. Copy Client ID and Client Secret below
# 5. Run `node scripts/get-gmail-token.js` to get your refresh token
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=           # The Gmail address emails are sent FROM

GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=
JWT_SECRET=
CLIENT_URL=http://localhost:5173
